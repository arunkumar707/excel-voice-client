{
  "name": "excel-voice-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "clean:sessions": "node -e \"try{require('fs').rmSync('.data',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev",
    "dev:fresh": "npm run clean && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint",
    "seed-template": "node scripts/create-default-template.cjs",
    "server:dev": "cd server && npm run start:dev",
    "server:build": "cd server && npm run build"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.2",
    "next": "15.5.4",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
