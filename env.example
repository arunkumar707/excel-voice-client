# Copy to .env.local in the project root. Restart `npm run dev` after changes.

# Whisper + GPT cleanup (optional — or use Browser dictate)
OPENAI_API_KEY=sk-proj-...
# Post-process transcript: fix spelling, Indian names/places, detect next row / clear (JSON)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional. Default whisper-1. If your account supports it, try: gpt-4o-transcribe
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ------------------------------------------------------------------------------
# Nest backend base URL — set to the scheme+host of your backend.
# Do NOT include a trailing slash or the /api/v1 prefix (added automatically).
#
# Development (same machine):
#   NEXT_PUBLIC_NEST_API_URL=http://127.0.0.1:3005
#
# Production / deployed:
#   NEXT_PUBLIC_NEST_API_URL=https://api.yourapp.com
#
# Leave EMPTY (or omit) to use relative requests — only works when the frontend
# and backend are served from the same origin/host.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_NEST_API_URL=http://127.0.0.1:3005

# MySQL: copy server/.env.example → server/.env and set DB_USER / DB_PASSWORD / DB_NAME
